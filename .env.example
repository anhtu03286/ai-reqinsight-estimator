# Application
APP_ENV=development
SECRET_KEY=change-me-in-production-min-32-chars
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://reqinsight:reqinsight@localhost:5432/reqinsight
DATABASE_SYNC_URL=postgresql://reqinsight:reqinsight@localhost:5432/reqinsight

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage (MinIO local / S3 prod)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=reqinsight-documents
STORAGE_USE_SSL=false

# LLM
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# OCR
TESSERACT_CMD=/usr/bin/tesseract

# PM Tools (per-org config stored in DB, these are app-level defaults)
JIRA_BASE_URL=
LINEAR_API_URL=https://api.linear.app/graphql
CLICKUP_API_URL=https://api.clickup.com/api/v2
